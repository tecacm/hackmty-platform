{
  "expo": {
    "name": "hackmty",
    "slug": "hackmty-platform-dev",
    "version": "1.0.0",
    "scheme": "hackmty-platform",
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "bundleIdentifier": "com.hackmty",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "newArchEnabled": true,
    "experiments": {
      "reactCanary": true
    },
    "plugins": [
      "expo-image",
      "./sdk-lockdown"
    ],
    "android": {
      "package": "com.hackmty"
    }
  }
}
